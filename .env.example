# ===========================================
# SuperMart Pro - Environment Configuration
# Copy this file to .env and fill in your values
# ===========================================

# -----------------------------------------
# Django Configuration
# -----------------------------------------
DJANGO_ENV=development
SECRET_KEY=your-super-secret-key-change-in-production-min-50-chars
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# -----------------------------------------
# Database Configuration
# -----------------------------------------
DB_ENGINE=django.db.backends.postgresql
DB_NAME=supermart_db
DB_USER=supermart
DB_PASSWORD=your-secure-database-password
DB_HOST=localhost
DB_PORT=5432

# -----------------------------------------
# Redis Configuration
# -----------------------------------------
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# -----------------------------------------
# Security Settings
# -----------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://localhost:8080

# JWT Settings (in minutes)
JWT_ACCESS_TOKEN_LIFETIME=60
JWT_REFRESH_TOKEN_LIFETIME=10080

# -----------------------------------------
# Email Configuration
# -----------------------------------------
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=SuperMart Pro <noreply@supermart.pro>

# -----------------------------------------
# AWS Configuration (Optional)
# -----------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=us-east-1

# -----------------------------------------
# Firebase Configuration (Optional)
# -----------------------------------------
FIREBASE_CREDENTIALS_PATH=./firebase-credentials.json
FIREBASE_PROJECT_ID=

# -----------------------------------------
# Sentry Error Tracking (Optional)
# -----------------------------------------
SENTRY_DSN=

# -----------------------------------------
# Docker Compose Settings
# -----------------------------------------
BACKEND_PORT=8000
DB_PORT=5432
REDIS_PORT=6379
FLOWER_PORT=5555
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# Flower (Celery Monitoring)
FLOWER_USER=admin
FLOWER_PASSWORD=secure-flower-password

# -----------------------------------------
# AI/ML Configuration
# -----------------------------------------
ENABLE_AI_PREDICTIONS=True
AI_MODEL_PATH=./ml_models/

# -----------------------------------------
# Third-party API Keys
# -----------------------------------------
# Currency Exchange API
EXCHANGE_RATE_API_KEY=

# OpenFoodFacts API (for product data)
OPENFOODFACTS_USER_AGENT=SuperMartPro/2.0

# Twilio (for SMS)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
